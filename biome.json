{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "includes": [
      "**/frameworks/ts/src/**/*.ts",
      "**/frameworks/ts/tests/**/*.ts",
      "**/frameworks/ts/template/src/**/*.ts",
      "**/frameworks/ts/template/tests/**/*.ts",
      "**/tools/**/src/**/*.ts",
      "**/tools/**/tests/**/*.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
